{
  "name": "@knowflow/api",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "tsx src/index.ts",
    "start:docker": "tsx src/index.ts",
    "licenses:check": "license-checker-rseidelsohn --production --summary --excludePrivatePackages",
    "licenses:report": "license-checker-rseidelsohn --production --excludePrivatePackages --out THIRD_PARTY_LICENSES.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@knowflow/ai": "workspace:*",
    "@knowflow/db": "workspace:*",
    "@knowflow/shared": "workspace:*",
    "ai": "^4.3.16",
    "drizzle-orm": "^0.39.3",
    "hono": "^4.7.7",
    "undici": "^6.26.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
