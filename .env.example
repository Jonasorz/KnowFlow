# KnowFlow server settings
#
# Most API keys are configured in the app Settings page and stored in the
# local SQLite database. This file is for server-level runtime options.

# API server port
PORT=3001

# API bind host. Keep 127.0.0.1 for local-only use.
HOST=127.0.0.1

# Web app port
WEB_PORT=5173

# Optional API URL used by the web dev/preview proxy.
# If unset, it defaults to http://127.0.0.1:$PORT.
# KNOWFLOW_API_URL=http://127.0.0.1:3001

# Optional ffmpeg binary path for podcast transcription compression.
# If unset, KnowFlow uses `ffmpeg` from PATH.
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# Optional frontend origins for CORS. Comma-separated.
# If unset, it defaults to http://localhost:$WEB_PORT,http://127.0.0.1:$WEB_PORT.
# Example: http://localhost:5173,http://127.0.0.1:5173
KNOWFLOW_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional custom data directory.
# If unset, KnowFlow uses a platform-specific user data directory.
# Example Linux/macOS:
# KNOWFLOW_DATA_DIR=/home/you/.local/share/knowflow
# Example Windows:
# KNOWFLOW_DATA_DIR=C:\Users\you\AppData\Roaming\KnowFlow

# Enable debug logs written to local log files. Disabled by default.
KNOWFLOW_DEBUG=false

# Allow temporary public file hosts as a transcription upload fallback.
# Disabled by default for privacy.
KNOWFLOW_ALLOW_PUBLIC_TRANSCRIPTION_UPLOADS=false
