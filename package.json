{
  "name": "knowflow",
  "private": true,
  "version": "0.1.4",
  "description": "KnowFlow — Multi-source content aggregation reader",
  "license": "MIT",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "start:docker": "node scripts/docker-start.mjs",
    "lint": "turbo lint",
