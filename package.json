    "db:migrate": "turbo db:migrate"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "license-checker-rseidelsohn": "^5.0.1",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
